rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: settings
    // Document ID: global
    // Fields:
    //   - backgroundImageUrl: string (required, URL)
    //   - updatedAt: timestamp
    //   - updatedBy: string (UID)
    //
    // Collection: users
    // Document ID: {userId}
    // Fields:
    //   - email: string (required, email)
    //   - role: string (required, ['admin', 'user'])
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
         (request.auth.token.email == "dragonballsam86@gmail.com" && request.auth.token.email_verified == true));
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isValidSettings(data) {
      return data.keys().hasAll(['backgroundImageUrl']) &&
             data.backgroundImageUrl is string &&
             data.backgroundImageUrl.size() < 2000;
    }

    function isValidUser(data) {
      return data.keys().hasAll(['email', 'role']) &&
             data.email is string &&
             data.role in ['admin', 'user'];
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /settings/global {
      allow read: if true; // Publicly readable to show background
      allow write: if isAdmin() && isValidSettings(request.resource.data);
    }

    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isAuthenticated() && isValidUser(request.resource.data) && 
                    ((isOwner(userId) && request.resource.data.role == 'user') || isAdmin());
      allow update: if isAdmin() && isValidUser(request.resource.data);
    }
  }
}
